# Database
# Local: SQLite file path
DATABASE_URL=sqlite:///./data/rupee_radar.db
# Production (Railway): PostgreSQL plugin connection string
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Upload limits
MAX_UPLOAD_SIZE_MB=10

# Session privacy — auto-expire analysis data after N hours
SESSION_TTL_HOURS=72

# ── Groq LLM ─────────────────────────────────────────────────────────────────
# Model: llama-3.3-70b-versatile
# Free-tier hard limits: 30 RPM · 1 K TPM · 12 K RPD · 100 K TPD
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Groq quota limits — must match your console tier exactly.
# These values enforce the free-tier limits for llama-3.3-70b-versatile.
GROQ_RPM=30
GROQ_TPM=1000
GROQ_RPD=12000
GROQ_TPD=100000

# ── LLM categorization guards (tuned for 1 K TPM) ────────────────────────────
# Max tokens sent per Groq request (prompt + estimated output).
# Keeps each batch well under the 1 K TPM window.
GROQ_MAX_TOKENS_PER_REQUEST=350

# Max unmatched transactions sent to LLM per upload.
# At ~350 tokens/request and 1 K TPM, 15 txns ≈ 1-2 requests/upload.
GROQ_MAX_TXNS_PER_UPLOAD=15

# Hard wall-clock budget for all LLM calls during a single upload (seconds).
# Prevents a slow Groq response from blocking the HTTP request indefinitely.
GROQ_UPLOAD_TIME_BUDGET_SEC=45

# Max characters of description_clean sent per transaction to the LLM.
# Keeps token estimates accurate and avoids prompt bloat.
GROQ_MAX_DESCRIPTION_CHARS=48

# ── Frontend (Vercel) ─────────────────────────────────────────────────────────
# Set to your Railway API base URL (no trailing slash) before deploying.
# VITE_API_URL=https://your-app.up.railway.app
